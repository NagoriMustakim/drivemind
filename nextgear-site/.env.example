# nextgear-site (dealer website) — copy to .env.local and fill in.
# All values are SERVER-ONLY. Never expose these to the client bundle.

# Dealer Supabase project (its own DB — holds raw inventory)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bearer token that protects GET /api/cars (DriveMind admin uses it to sync).
# Choose any strong random string; you'll paste the same value into the admin Sync form.
DEALER_API_TOKEN=

# Public base URL of this site (used to build absolute car detail URLs).
SITE_URL=http://localhost:3000

SITE_URL=https://<nextgear-site>.vercel.app
NEXT_PUBLIC_OTTO_SRC=https://<chatbot>.vercel.app/otto.js
NEXT_PUBLIC_OTTO_API=https://<chatbot>.vercel.app/api
NEXT_PUBLIC_DEALER_ID=nextgear
