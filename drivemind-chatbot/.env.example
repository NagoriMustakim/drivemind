# drivemind-chatbot (assistant runtime) — copy to .env.local and fill in.
# All values are SERVER-ONLY (never shipped in the widget bundle).

# Chatbot KB Supabase project (SAME project as drivemind-admin; chatbot READS it)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key — used only to embed the short user query (RETRIEVAL_QUERY)
GEMINI_API_KEY=

# Anthropic (Claude) — the default answer model
ANTHROPIC_API_KEY=

# Secret for signing short-lived session JWTs (any strong random string)
JWT_SECRET=

# Answer-model config flag: claude (default) | gemini | openai
ANSWER_MODEL=claude

# Specific Claude model id. Defaults to Haiku 4.5 — much faster than Sonnet for
# this short, structured task (the main latency win). Set to claude-sonnet-4-6
# if you'd rather trade a few seconds for maximum answer quality.
ANSWER_MODEL_ID=claude-haiku-4-5-20251001
