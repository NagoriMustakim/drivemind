{
  "name": "drivemind-chatbot",
  "version": "0.1.0",
  "private": true,
  "description": "DriveMind Chatbot — assistant runtime + embeddable Otto widget (DriveMind APP 3)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "widget:build": "vite build --config widget/vite.config.ts && mkdir -p public && cp -f widget/dist/otto.js public/otto.js",
    "widget:size": "node widget/check-size.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/genai": "^0.14.0",
    "@supabase/supabase-js": "^2.45.0",
    "jose": "^5.6.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "preact": "^10.23.0",
    "preact-render-to-string": "^6.5.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
