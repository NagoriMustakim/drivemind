# drivemind-admin (control plane) — copy to .env.local and fill in.
# All values are SERVER-ONLY.

# Chatbot KB Supabase project (separate from the dealer DB; enable pgvector here)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key (free tier) — use_case extraction + document embeddings.
# IMPORTANT: create this in Google AI Studio (https://aistudio.google.com/apikey)
# so it has free-tier quota. A GCP-console key from a billing-disabled project
# reports "limit: 0" (429) and sync will fail.
GEMINI_API_KEY=

# Optional model overrides (defaults shown). Change if your key's free tier
# doesn't include these models.
# GEMINI_EXTRACT_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# use_case strategy: "llm" (default; auto-falls back to templates on quota errors)
# or "template" (skip the extraction LLM entirely — fastest fully-free path,
# uses only embeddings). Set this to template if generate_content shows limit: 0.
# GEMINI_EXTRACTION=template
